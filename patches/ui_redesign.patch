diff --git a/ui/src/components/BallTracer.css b/ui/src/components/BallTracer.css
new file mode 100644
index 0000000..98fdaa8
--- /dev/null
+++ b/ui/src/components/BallTracer.css
@@ -0,0 +1,359 @@
+/* Ball Tracer — virtual range panel in the Live view.
+   Same instrument vocabulary as the metric modules: bordered surface,
+   tracked label header, mono readouts. The range itself is drawn in
+   theme tokens so it holds up in both graphite and light panel. */
+
+.ball-tracer {
+  background: var(--surface);
+  border: 1px solid var(--border);
+  border-radius: var(--radius-sm);
+  flex-shrink: 0;
+  overflow: hidden;
+}
+
+.ball-tracer__header {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: var(--space-sm);
+  padding: var(--space-xs) var(--space-md);
+  border-bottom: 1px solid var(--border);
+}
+
+.ball-tracer--folded .ball-tracer__header {
+  border-bottom: none;
+}
+
+.ball-tracer__title {
+  font-size: var(--text-xs);
+  font-weight: 600;
+  letter-spacing: 0.08em;
+  text-transform: uppercase;
+  color: var(--ink-muted);
+}
+
+.ball-tracer__controls {
+  display: flex;
+  align-items: center;
+  gap: var(--space-sm);
+}
+
+/* Ball-detected chip — dot + spelled-out state, never color alone */
+.ball-tracer__ball-chip {
+  display: inline-flex;
+  align-items: center;
+  gap: var(--space-xs);
+  font-family: var(--font-mono);
+  font-size: var(--text-xs);
+  letter-spacing: 0.06em;
+  text-transform: uppercase;
+  color: var(--ink-muted);
+}
+
+.ball-tracer__ball-dot {
+  width: 8px;
+  height: 8px;
+  border-radius: 50%;
+  border: 1px solid var(--border-strong);
+  background: transparent;
+}
+
+.ball-tracer__ball-chip--detected {
+  color: var(--ok);
+}
+
+.ball-tracer__ball-chip--detected .ball-tracer__ball-dot {
+  background: var(--ok);
+  border-color: var(--ok);
+}
+
+/* History selector — the same segmented-key vocabulary, one size down */
+.ball-tracer__history {
+  display: inline-flex;
+  align-items: stretch;
+  border: 1px solid var(--border-strong);
+  border-radius: var(--radius-md);
+  background: var(--surface);
+  overflow: hidden;
+}
+
+.ball-tracer__history-button {
+  border: none;
+  background: transparent;
+  color: var(--ink-muted);
+  padding: 0.2rem 0.5rem;
+  min-height: 26px;
+  font-size: var(--text-xs);
+  font-weight: 600;
+  letter-spacing: 0.06em;
+  text-transform: uppercase;
+  cursor: pointer;
+  transition: background var(--transition-fast), color var(--transition-fast);
+}
+
+.ball-tracer__history-button + .ball-tracer__history-button {
+  border-left: 1px solid var(--border-strong);
+}
+
+.ball-tracer__history-button:hover {
+  color: var(--ink);
+}
+
+.ball-tracer__history-button--active {
+  background: var(--amber);
+  color: var(--on-amber);
+}
+
+.ball-tracer__fold {
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  width: 28px;
+  height: 26px;
+  border: 1px solid var(--border-strong);
+  border-radius: var(--radius-md);
+  background: transparent;
+  color: var(--ink-secondary);
+  cursor: pointer;
+  transition: border-color var(--transition-fast), color var(--transition-fast);
+}
+
+.ball-tracer__fold:hover {
+  border-color: var(--accent-border);
+  color: var(--ink);
+}
+
+/* Clear the drawn traces (display only; the session is untouched) */
+.ball-tracer__clear {
+  border: 1px solid var(--border-strong);
+  border-radius: var(--radius-md);
+  background: transparent;
+  color: var(--ink-secondary);
+  padding: 0.2rem 0.5rem;
+  min-height: 26px;
+  font-size: var(--text-xs);
+  font-weight: 600;
+  letter-spacing: 0.06em;
+  text-transform: uppercase;
+  cursor: pointer;
+  transition: border-color var(--transition-fast), color var(--transition-fast);
+}
+
+.ball-tracer__clear:hover:not(:disabled) {
+  border-color: var(--accent-border);
+  color: var(--ink);
+}
+
+.ball-tracer__clear:disabled {
+  opacity: 0.4;
+  cursor: default;
+}
+
+/* ---- The range ---- */
+
+.ball-tracer__stage {
+  /* Sky above the horizon is simply the deeper body tone */
+  background: var(--bg);
+}
+
+.ball-tracer__svg {
+  display: block;
+  width: 100%;
+  height: auto;
+  max-height: 58vh;
+}
+
+.ball-tracer__rough {
+  fill: var(--surface);
+}
+
+.ball-tracer__horizon {
+  stroke: var(--border-strong);
+  stroke-width: 1;
+}
+
+.ball-tracer__fairway {
+  fill: var(--surface-2);
+}
+
+/* Alternating mow bands between yardage lines — depth cue, kept subtle */
+.ball-tracer__stripe {
+  fill: var(--surface-3);
+  opacity: 0.45;
+}
+
+.ball-tracer__edge {
+  fill: none;
+  stroke: var(--border-strong);
+  stroke-width: 1.5;
+}
+
+.ball-tracer__centerline {
+  stroke: var(--border);
+  stroke-width: 1;
+  stroke-dasharray: 6 8;
+}
+
+.ball-tracer__tee {
+  fill: var(--surface-3);
+  stroke: var(--border-strong);
+  stroke-width: 1;
+}
+
+.ball-tracer__distline {
+  stroke: var(--border-strong);
+  stroke-width: 1;
+}
+
+.ball-tracer__distlabel {
+  font-family: var(--font-mono);
+  letter-spacing: 0.04em;
+  fill: var(--ink-secondary);
+  /* Halo so labels stay legible over the stripes */
+  paint-order: stroke;
+  stroke: var(--surface);
+  stroke-width: 3px;
+}
+
+.ball-tracer__landing {
+  fill: var(--accent-text);
+}
+
+/* Landed outside the 50-yd fairway: dot goes warn-colored and the carry
+   marker says "rough" in words — never color alone. */
+.ball-tracer__landing--rough {
+  fill: var(--warn);
+}
+
+/* Ground dimension: "25 yd" on each half of the fairway near the tee */
+.ball-tracer__width-label {
+  font-family: var(--font-mono);
+  font-size: 11px;
+  letter-spacing: 0.06em;
+  fill: var(--ink-muted);
+}
+
+/* One expanding pulse at the landing spot, timed to the trace draw-in.
+   Starts invisible: under prefers-reduced-motion the animation collapses
+   and the ring simply never shows. */
+.ball-tracer__ring {
+  fill: none;
+  stroke: var(--accent-text);
+  stroke-width: 2;
+  opacity: 0;
+  animation: tracer-ring 0.7s cubic-bezier(0.22, 1, 0.36, 1) var(--trace-delay, 0.85s);
+}
+
+@keyframes tracer-ring {
+  0% {
+    opacity: 0.7;
+    r: 3;
+  }
+  100% {
+    opacity: 0;
+    r: 18;
+  }
+}
+
+/* Prior traces: present but quiet, so the dispersion story reads without
+   shouting over the latest flight */
+.ball-tracer__trace-prior {
+  fill: none;
+  stroke: var(--accent-border);
+  stroke-width: 1.5;
+  stroke-linecap: round;
+  stroke-linejoin: round;
+  opacity: 0.35;
+}
+
+/* Latest flight: the amber trace draws in over the shot's REAL hang time
+   (--trace-duration is set from the sim's flight_time_s). The easing is a
+   gentle ease-out — the ball covers ground fastest off the face and slows
+   through the flight. pathLength=1 normalizes the dash math; the global
+   reduced-motion rule collapses the whole thing to an instant trace. */
+.ball-tracer__trace {
+  fill: none;
+  stroke: var(--accent-text);
+  stroke-width: 2.5;
+  stroke-linecap: round;
+  stroke-linejoin: round;
+  stroke-dasharray: 1;
+  stroke-dashoffset: 0;
+  animation: tracer-draw var(--trace-duration, 0.9s) cubic-bezier(0.3, 0.05, 0.65, 1);
+}
+
+/* Soft light under the live trace so it reads over the range dressing */
+.ball-tracer__trace-glow {
+  fill: none;
+  stroke: var(--accent-text);
+  stroke-width: 6;
+  stroke-linecap: round;
+  stroke-linejoin: round;
+  opacity: 0.35;
+  stroke-dasharray: 1;
+  stroke-dashoffset: 0;
+  animation: tracer-draw var(--trace-duration, 0.9s) cubic-bezier(0.3, 0.05, 0.65, 1);
+}
+
+/* Markers arrive with the ball, not before: apex label as it crests,
+   carry label + dot as it lands. Reduced motion collapses the delays. */
+.ball-tracer__marker,
+.ball-tracer__landing {
+  animation: tracer-appear 0.25s cubic-bezier(0.22, 1, 0.36, 1) both;
+}
+
+.ball-tracer__marker {
+  animation-delay: var(--trace-apex-delay, 0.4s);
+}
+
+.ball-tracer__marker--carry,
+.ball-tracer__landing {
+  animation-delay: var(--trace-delay, 0.85s);
+}
+
+@keyframes tracer-appear {
+  from {
+    opacity: 0;
+  }
+  to {
+    opacity: 1;
+  }
+}
+
+@keyframes tracer-draw {
+  from {
+    stroke-dashoffset: 1;
+  }
+  to {
+    stroke-dashoffset: 0;
+  }
+}
+
+.ball-tracer__marker {
+  font-family: var(--font-mono);
+  font-variant-numeric: tabular-nums;
+  font-size: 13px;
+  letter-spacing: 0.04em;
+  fill: var(--ink);
+}
+
+.ball-tracer__marker--carry {
+  fill: var(--accent-text);
+  font-weight: 600;
+  font-size: 14px;
+}
+
+.ball-tracer__hint {
+  font-family: var(--font-mono);
+  font-size: 11px;
+  letter-spacing: 0.06em;
+  text-transform: uppercase;
+  fill: var(--ink-muted);
+}
+
+/* Compact 7" kiosk: the stage cedes height to the metric grid */
+@media (max-height: 500px) {
+  .ball-tracer__svg {
+    max-height: 36vh;
+  }
+}
