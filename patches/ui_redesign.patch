--- /dev/null
+++ b/ui/src/stores/useThemePreferenceStore.ts
@@ -0,0 +1,49 @@
+import { create } from 'zustand';
+
+export type Theme = 'dark' | 'light';
+
+const STORAGE_KEY = 'openflight.theme';
+
+function readStoredTheme(): Theme {
+  if (typeof window === 'undefined') {
+    return 'dark';
+  }
+
+  const storedValue = window.localStorage.getItem(STORAGE_KEY);
+  return storedValue === 'light' ? 'light' : 'dark';
+}
+
+function applyTheme(theme: Theme) {
+  if (typeof document === 'undefined') {
+    return;
+  }
+
+  // Dark is the stylesheet default; only light needs the attribute.
+  if (theme === 'light') {
+    document.documentElement.setAttribute('data-theme', 'light');
+  } else {
+    document.documentElement.removeAttribute('data-theme');
+  }
+}
+
+interface ThemePreferenceState {
+  theme: Theme;
+  setTheme: (theme: Theme) => void;
+}
+
+export const useThemePreferenceStore = create<ThemePreferenceState>((set) => {
+  const initial = readStoredTheme();
+  applyTheme(initial);
+
+  return {
+    theme: initial,
+    setTheme: (theme) => {
+      if (typeof window !== 'undefined') {
+        window.localStorage.setItem(STORAGE_KEY, theme);
+      }
+
+      applyTheme(theme);
+      set({ theme });
+    },
+  };
+});
