+"""Tune ballistics aero constants against the TrackMan tour dataset.
+
+Conditions are pinned to ISA sea level (rho = 1.225 kg/m3, 15 C) and the
+target is RAW carry (no roll, no thin-air help): the constants alone have
+to reproduce the tour numbers.
+
+Targets per club: carry (weight 1.0), apex (0.7), landing angle (0.3).
+Optimizer: differential evolution (global) then Nelder-Mead polish.
+"""
+
+import sys
+
+sys.path.insert(0, "src")  # run from the repo root
+
+import numpy as np
+from scipy.optimize import differential_evolution, minimize
+
+import openflight.ballistics as B
+
+# club, ball mph, launch deg, spin rpm, carry yds, apex yds, land deg
+ROWS = [
+    ("Driver", 167, 10.9, 2686, 275, 32, 38),
+    ("3 Wood", 158, 9.2, 3655, 243, 30, 43),
+    ("5 Wood", 152, 9.4, 4350, 230, 31, 47),
+    ("Hybrid", 146, 10.2, 4437, 225, 29, 47),
+    ("3 Iron", 142, 10.4, 4630, 212, 27, 46),
+    ("4 Iron", 137, 11.0, 4836, 203, 28, 48),
+    ("5 Iron", 132, 12.1, 5361, 194, 31, 49),
+    ("6 Iron", 127, 14.1, 6231, 183, 30, 50),
+    ("7 Iron", 120, 16.3, 7097, 172, 32, 50),
+    ("8 Iron", 115, 18.1, 7998, 160, 31, 50),
+    ("9 Iron", 109, 20.4, 8647, 148, 31, 51),
+    ("PW", 102, 24.2, 9304, 136, 29, 52),
+]
+
+W_CARRY, W_APEX, W_LAND = 1.0, 0.7, 0.3
+
+
+def set_params(p):
+    B.CD_BASE, B.CD_SPIN_COEFF, B.CL_SATURATION, B.CL_HALF_SP, B.SPIN_DECAY_RATE = p
+
+
+def score(p, dt):
+    # Keep parameters physical; punish the optimizer for wandering out.
+    for v, (lo, hi) in zip(p, BOUNDS):
+        if not (lo <= v <= hi):
+            return 1e6
+    set_params(p)
+    err = 0.0
+    for _, bs, la, spin, carry, apex, land in ROWS:
+        t = B.simulate(B.LaunchConditions(bs, la, 0.0, spin, 0.0, "measured"), dt=dt)
+        err += W_CARRY * ((t.carry_yards - carry) / carry) ** 2
+        err += W_APEX * ((t.apex_yards - apex) / apex) ** 2
+        err += W_LAND * ((t.landing_angle_deg - land) / land) ** 2
+    return err
+
+
+BOUNDS = [
+    (0.15, 0.30),   # CD_BASE
+    (0.02, 0.40),   # CD_SPIN_COEFF
+    (0.20, 0.50),   # CL_SATURATION
+    (0.03, 0.35),   # CL_HALF_SP
+    (0.015, 0.065), # SPIN_DECAY_RATE
+]
+
+# Coarse dt for the search (RK4 is nearly identical at 10 ms for this ODE);
+# final report re-validates at the production 2 ms.
+DT_SEARCH = 0.01
+
+start = (B.CD_BASE, B.CD_SPIN_COEFF, B.CL_SATURATION, B.CL_HALF_SP, B.SPIN_DECAY_RATE)
+print("baseline score:", round(score(start, DT_SEARCH), 5), flush=True)
+
+res = minimize(lambda p: score(p, DT_SEARCH), start, method="Nelder-Mead",
+               options={"xatol": 1e-4, "fatol": 1e-8, "maxiter": 500})
+best = res.x
+print("tuned score (coarse dt):", round(res.fun, 5), f"after {res.nfev} evals", flush=True)
+print("params CD_BASE=%.4f CD_SPIN=%.4f CL_SAT=%.4f CL_HALF=%.4f DECAY=%.4f" % tuple(best))
+
+# Full-resolution validation of the winner
+set_params(best)
+print(f"\n{'club':8} {'carry sim/tour':>15} {'err%':>7} {'apex sim/tour':>14} {'err%':>7} {'land':>10} {'time':>6}")
+ce, ae = [], []
+for name, bs, la, spin, carry, apex, land in ROWS:
+    t = B.simulate(B.LaunchConditions(bs, la, 0.0, spin, 0.0, "measured"))
+    c = 100 * (t.carry_yards - carry) / carry
+    a = 100 * (t.apex_yards - apex) / apex
+    ce.append(abs(c)); ae.append(abs(a))
+    print(f"{name:8} {t.carry_yards:6.0f}/{carry:<5} {c:+6.1f}% {t.apex_yards:6.1f}/{apex:<4} {a:+6.1f}% "
+          f"{t.landing_angle_deg:4.0f}/{land:<3} {t.flight_time_s:5.1f}s")
+print(f"\nmean |carry err| {np.mean(ce):.2f}%   mean |apex err| {np.mean(ae):.2f}%")
+
+# Physical sanity: coefficient values at driver-like and wedge-like spin params
+for sp in (0.08, 0.15, 0.30):
+    cd = best[0] + best[1] * sp
+    cl = best[2] * sp / (best[3] + sp)
+    print(f"Sp={sp:.2f}: Cd={cd:.3f} Cl={cl:.3f}")
+EOF_MARKER_NOT_NEEDED = True
