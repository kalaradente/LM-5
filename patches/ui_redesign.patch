+import { renderToString } from 'react-dom/server';
+import { describe, expect, it } from 'vitest';
+import type { Shot } from '../types/shot';
+import { StatsView } from './StatsView';
+
+function makeShot(overrides: Partial<Shot>): Shot {
+  return {
+    ball_speed_mph: 150,
+    club_speed_mph: 100,
+    smash_factor: 1.5,
+    estimated_carry_yards: 250,
+    carry_range: [240, 260],
+    club: 'driver',
+    timestamp: `2026-07-07T12:00:00Z-${Math.random()}`,
+    peak_magnitude: null,
+    launch_angle_vertical: 12,
+    launch_angle_horizontal: 0,
+    launch_angle_confidence: 0.8,
+    angle_source: 'radar',
+    club_angle_deg: null,
+    club_path_deg: null,
+    spin_axis_deg: null,
+    spin_rpm: 2600,
+    spin_confidence: 0.8,
+    spin_quality: 'high',
+    spin_source: 'measured',
+    carry_spin_adjusted: null,
+    ...overrides,
+  };
+}
+
+const playShot = makeShot({
+  trajectory: {
+    points: [
+      [0, 0, 0],
+      [251, 6, 0],
+    ],
+    apex_yards: 30, // = 90 ft
+    carry_yards: 251,
+    lateral_yards: 6,
+  },
+});
+const swing = makeShot({ mode: 'speed-training', ball_speed_mph: 0, club_speed_mph: 88.5 });
+
+// renderToString interleaves comment markers between text segments
+// ("All (<!-- -->1<!-- -->)"); strip them so plain-text assertions work.
+function renderPlain(ui: Parameters<typeof renderToString>[0]): string {
+  return renderToString(ui).replace(/<!-- -->/g, '');
+}
