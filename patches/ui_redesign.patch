+import { create } from 'zustand';
+
+export type TracerHistory = 'all' | 'last5' | 'latest';
+
+const FOLDED_KEY = 'openflight.tracer.folded';
+const HISTORY_KEY = 'openflight.tracer.history';
+
+function readStoredFolded(): boolean {
+  if (typeof window === 'undefined') return false;
+  return window.localStorage.getItem(FOLDED_KEY) === 'true';
+}
+
+function readStoredHistory(): TracerHistory {
+  if (typeof window === 'undefined') return 'all';
+  const v = window.localStorage.getItem(HISTORY_KEY);
+  return v === 'last5' || v === 'latest' ? v : 'all';
+}
+
+interface TracerPreferenceState {
+  folded: boolean;
+  history: TracerHistory;
+  setFolded: (folded: boolean) => void;
+  setHistory: (history: TracerHistory) => void;
+}
+
+export const useTracerPreferenceStore = create<TracerPreferenceState>((set) => ({
+  folded: readStoredFolded(),
+  history: readStoredHistory(),
+  setFolded: (folded) => {
+    if (typeof window !== 'undefined') {
+      window.localStorage.setItem(FOLDED_KEY, String(folded));
+    }
+    set({ folded });
+  },
+  setHistory: (history) => {
+    if (typeof window !== 'undefined') {
+      window.localStorage.setItem(HISTORY_KEY, history);
+    }
+    set({ history });
+  },
+}));
