@@ -0,0 +1,150 @@
+import { renderToString } from 'react-dom/server';
+import { describe, expect, it } from 'vitest';
+import type { CameraStatus } from '../stores/useCameraStore';
+import type { Shot } from '../types/shot';
+import { project } from '../utils/tracerProjection';
+import { BallTracer } from './BallTracer';
+
+// Strip SSR comment markers so plain-text assertions work.
+function renderPlain(ui: Parameters<typeof renderToString>[0]): string {
+  return renderToString(ui).replace(/<!-- -->/g, '');
+}
+
+const cameraOff: CameraStatus = {
+  available: false,
+  enabled: false,
+  streaming: false,
+  ball_detected: false,
+  ball_confidence: 0,
+};
+
+function makeShot(overrides: Partial<Shot>): Shot {
+  return {
+    ball_speed_mph: 150,
+    club_speed_mph: 100,
+    smash_factor: 1.5,
+    estimated_carry_yards: 250,
+    carry_range: [240, 260],
+    club: 'driver',
+    timestamp: `t-${Math.random()}`,
+    peak_magnitude: null,
+    launch_angle_vertical: 12,
+    launch_angle_horizontal: 0,
+    launch_angle_confidence: 0.8,
+    angle_source: 'radar',
+    club_angle_deg: null,
+    club_path_deg: null,
+    spin_axis_deg: null,
+    spin_rpm: 2600,
+    spin_confidence: 0.8,
+    spin_quality: 'high',
+    spin_source: 'measured',
+    carry_spin_adjusted: null,
+    ...overrides,
+  };
+}
+
+const tracedShot = makeShot({
+  trajectory: {
+    points: [
+      [0, 0, 0],
+      [120, 2, 28],
+      [251, 6.5, 0],
+    ],
+    apex_yards: 31.5,
+    carry_yards: 251.2,
+    lateral_yards: 6.5,
+  },
+});
+
+describe('project', () => {
+  it('recedes toward the horizon and center with distance', () => {
+    const near = project(50, 25, 0);
+    const far = project(400, 25, 0);
+    // Farther ground points sit higher on screen (smaller v) and closer
+    // to the vertical center line (smaller |u - center|).
+    expect(far.v).toBeLessThan(near.v);
+    expect(Math.abs(far.u - 360)).toBeLessThan(Math.abs(near.u - 360));
+  });
+
+  it('maps lateral right to the right of center and height upward', () => {
+    const right = project(100, 10, 0);
+    const left = project(100, -10, 0);
+    expect(right.u).toBeGreaterThan(360);
+    expect(left.u).toBeLessThan(360);
+    const high = project(100, 0, 30);
+    const ground = project(100, 0, 0);
+    expect(high.v).toBeLessThan(ground.v);
+  });
+});
+
+describe('BallTracer', () => {
+  it('draws the trace with apex and carry markers', () => {
+    const html = renderPlain(
+      <BallTracer shots={[tracedShot]} latestShot={tracedShot} cameraStatus={cameraOff} selectedClub="driver" />,
+    );
+    expect(html).toContain('ball-tracer__trace');
+    // Peak height is always feet: 31.5 yd apex = 94.5 ft → 95 ft
+    expect(html).toContain('▴ 95 ft');
+    expect(html).toContain('251 yds');
+    // On the fairway: no rough call on the carry marker, no warn dot
+    expect(html).not.toContain('· rough');
+    expect(html).not.toContain('ball-tracer__landing--rough');
+  });
+
+  it('labels out-of-fairway landings as rough (word + warn dot)', () => {
+    const sliced = makeShot({
+      trajectory: {
+        points: [
+          [0, 0, 0],
+          [120, 15, 28],
+          [230, 32, 0],
+        ],
+        apex_yards: 30,
+        carry_yards: 230,
+        lateral_yards: 32, // beyond the ±25 yd fairway
+      },
+    });
+    const html = renderPlain(
+      <BallTracer shots={[sliced]} latestShot={sliced} cameraStatus={cameraOff} selectedClub="driver" />,
+    );
+    expect(html).toContain('230 yds · rough');
+    expect(html).toContain('ball-tracer__landing--rough');
+  });
+
+  it('numbers the yardage lines on both edges, 10/25 then 50s to 400', () => {
+    const html = renderPlain(
+      <BallTracer shots={[]} latestShot={null} cameraStatus={cameraOff} selectedClub="driver" />,
+    );
+    for (const yds of [10, 25, 50, 100, 150, 200, 250, 300, 350, 400]) {
+      const matches = html.match(new RegExp(`>${yds}</text>`, 'g')) ?? [];
+      expect(matches.length, `yardage ${yds} labeled on both edges`).toBe(2);
+    }
+    // Width dimension on each fairway half
+    expect((html.match(/25 yd</g) ?? []).length).toBe(2);
+  });
+
+  it('offers a clear control for the drawn traces', () => {
+    const html = renderPlain(
+      <BallTracer shots={[tracedShot]} latestShot={tracedShot} cameraStatus={cameraOff} selectedClub="driver" />,
+    );
+    expect(html).toContain('ball-tracer__clear');
+    expect(html).toContain('Clear');
+  });
+
+  it('shows an honest hint when the shot has no flight data', () => {
+    const bare = makeShot({ trajectory: null });
+    const html = renderPlain(
+      <BallTracer shots={[bare]} latestShot={bare} cameraStatus={cameraOff} selectedClub="driver" />,
+    );
+    expect(html).toContain('no flight data for last shot');
+    expect(html).not.toContain('ball-tracer__trace"');
+  });
+
+  it('shows the awaiting state before any shot', () => {
+    const html = renderPlain(
+      <BallTracer shots={[]} latestShot={null} cameraStatus={cameraOff} selectedClub="driver" />,
+    );
+    expect(html).toContain('awaiting first shot');
+  });
+});
diff --git a/ui/src/components/BallTracer.tsx b/ui/src/components/BallTracer.tsx
new file mode 100644
index 0000000..fc7a557
--- /dev/null
+++ b/ui/src/components/BallTracer.tsx
@@ -0,0 +1,370 @@
+import { useEffect, useRef, useState } from 'react';
+import type { Shot } from '../types/shot';
+import type { CameraStatus } from '../stores/useCameraStore';
+import { useTracerPreference } from '../state/useTracerPreference';
+import type { TracerHistory } from '../stores/useTracerPreferenceStore';
+import { PEAK_HEIGHT_UNIT, formatPeakHeight } from '../utils/units';
+import {
+  FAIRWAY_NEAR_X,
+  HALF_WIDTH,
+  RANGE_DEPTH,
+  VIEW_H,
+  VIEW_W,
+  V_HORIZON,
+  pathFrom,
+  project,
+} from '../utils/tracerProjection';
+import './BallTracer.css';
+
+/**
+ * Ball tracer — a virtual driving range seen from behind the ball, the way
+ * you'd watch a shot fly away from you at a real range. Traces are the
+ * server's RK4 flight path (the same physics that produces spin-adjusted
+ * carry); shots without resolvable launch data draw nothing.
+ *
+ * The range is 50 yds of fairway (25 each side of the aim line, and the
+ * width is dimensioned on the ground) inside full-width rough: shots that
+ * leave the fairway land in the rough and are labeled as such. Traces can
+ * be cleared manually and reset automatically when the club changes.
+ */
+
+// Yardage lines: tight near-field reads (10, 25), then every 50 to 400.
+const DISTANCE_MARKS = [10, 25, 50, 100, 150, 200, 250, 300, 350, 400];
+// Mow-stripe band boundaries (tee → beyond the last line).
+const BAND_EDGES = [0, ...DISTANCE_MARKS, RANGE_DEPTH];
+
+const HISTORY_OPTIONS: { id: TracerHistory; label: string }[] = [
+  { id: 'all', label: 'All' },
+  { id: 'last5', label: '5' },
+  { id: 'latest', label: 'Last' },
+];
+
+function groundPoly(fromX: number, toX: number): string {
+  return [
+    project(fromX, -HALF_WIDTH, 0),
+    project(toX, -HALF_WIDTH, 0),
+    project(toX, HALF_WIDTH, 0),
+    project(fromX, HALF_WIDTH, 0),
+  ]
+    .map((p) => `${p.u.toFixed(1)},${p.v.toFixed(1)}`)
+    .join(' ');
+}
+
+interface BallTracerProps {
+  shots: Shot[];
+  /** Latest ball shot (never a speed-training swing). */
+  latestShot: Shot | null;
+  cameraStatus: CameraStatus;
+  /** Currently selected club — a change auto-clears the drawn traces. */
+  selectedClub: string;
+}
+
+export function BallTracer({ shots, latestShot, cameraStatus, selectedClub }: BallTracerProps) {
+  const { folded, history, setFolded, setHistory } = useTracerPreference();
+
+  // Traces drawn = shots hit since the last clear. Clearing is a display
+  // action only — the session (stats, ledger) is untouched.
+  const [clearIndex, setClearIndex] = useState(0);
+  const prevClub = useRef(selectedClub);
+  useEffect(() => {
+    if (prevClub.current !== selectedClub) {
+      prevClub.current = selectedClub;
+      setClearIndex(shots.length);
+    }
+    // eslint-disable-next-line react-hooks/exhaustive-deps -- shots.length is read, not a trigger: only a club change clears
+  }, [selectedClub]);
+  // Session cleared underneath us (shots array shrank): show everything again.
+  const effectiveClearIndex = clearIndex > shots.length ? 0 : clearIndex;
+
+  const visibleShots = shots.slice(effectiveClearIndex);
+  const latestVisible =
+    latestShot !== null && visibleShots.some((s) => s.timestamp === latestShot.timestamp)
+      ? latestShot
+      : null;
+  const latestTraj = latestVisible?.trajectory ?? null;
+
+  // Prior traces per the history setting (latest excluded — it gets the
+  // bright animated stroke).
+  const priorTraces =
+    history === 'latest'
+      ? []
+      : visibleShots
+          .filter(
+            (s) =>
+              s.mode !== 'speed-training' &&
+              s.trajectory &&
+              s.timestamp !== latestVisible?.timestamp,
+          )
+          .slice(history === 'last5' ? -5 : 0)
+          .map((s) => s.trajectory!);
+
+  // Apex marker: the sampled point closest to the sim's reported apex.
+  let apexPoint: { u: number; v: number } | null = null;
+  if (latestTraj && latestTraj.points.length > 0) {
+    const apex = latestTraj.points.reduce((a, b) => (b[2] > a[2] ? b : a));
+    apexPoint = project(apex[0], apex[1], apex[2]);
+  }
+  const landing = latestTraj?.points[latestTraj.points.length - 1];
+  const landingPoint = landing ? project(landing[0], landing[1], 0) : null;
+  // Off the 50-yd fairway = in the rough. Said with a word, not color alone.
+  const landedInRough = latestTraj !== null && Math.abs(latestTraj.lateral_yards) > HALF_WIDTH;
+
+  const teeMat = [
+    project(-2.5, -2.5, 0),
+    project(1.5, -2.5, 0),
+    project(1.5, 2.5, 0),
+    project(-2.5, 2.5, 0),
+  ]
+    .map((p) => `${p.u.toFixed(1)},${p.v.toFixed(1)}`)
+    .join(' ');
+
+  return (
+    <section className={`ball-tracer ${folded ? 'ball-tracer--folded' : ''}`} aria-label="Ball tracer">
+      <div className="ball-tracer__header">
+        <span className="ball-tracer__title">Ball Tracer</span>
+        <div className="ball-tracer__controls">
+          {cameraStatus.available && (
+            <span
+              className={`ball-tracer__ball-chip ${
+                cameraStatus.ball_detected ? 'ball-tracer__ball-chip--detected' : ''
+              }`}
+            >
+              <span className="ball-tracer__ball-dot" aria-hidden="true" />
+              {cameraStatus.ball_detected ? 'Ball detected' : 'No ball'}
+            </span>
+          )}
+          <div className="ball-tracer__history" role="group" aria-label="Trace history">
+            {HISTORY_OPTIONS.map((opt) => (
+              <button
+                key={opt.id}
+                type="button"
+                className={`ball-tracer__history-button ${
+                  history === opt.id ? 'ball-tracer__history-button--active' : ''
+                }`}
+                onClick={() => setHistory(opt.id)}
+                aria-pressed={history === opt.id}
+                title={
+                  opt.id === 'all'
+                    ? 'Show every trace this session'
+                    : opt.id === 'last5'
+                      ? 'Show the last 5 traces'
+                      : 'Show only the latest trace'
+                }
+              >
+                {opt.label}
+              </button>
+            ))}
+          </div>
+          <button
+            type="button"
+            className="ball-tracer__clear"
+            onClick={() => setClearIndex(shots.length)}
+            disabled={visibleShots.length === 0}
+            title="Clear the drawn traces (session data is untouched)"
+          >
+            Clear
+          </button>
+          <button
+            type="button"
+            className="ball-tracer__fold"
+            onClick={() => setFolded(!folded)}
+            aria-expanded={!folded}
+            aria-label={folded ? 'Unfold ball tracer' : 'Fold ball tracer'}
+            title={folded ? 'Unfold' : 'Fold'}
+          >
+            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" width="16" height="16">
+              {folded ? <path d="M6 9l6 6 6-6" /> : <path d="M18 15l-6-6-6 6" />}
+            </svg>
+          </button>
+        </div>
+      </div>
+
+      {!folded && (
+        <div className="ball-tracer__stage">
+          <svg
+            viewBox={`0 0 ${VIEW_W} ${VIEW_H}`}
+            className="ball-tracer__svg"
+            role="img"
+            aria-label={
+              latestTraj
+                ? `Flight path: ${latestTraj.carry_yards} yards carry, apex ${formatPeakHeight(latestTraj.apex_yards)} feet${landedInRough ? ', landed in the rough' : ''}`
+                : 'Virtual range, awaiting a shot'
+            }
+          >
+            <defs>
+              {/* Sky: deep body tone warming faintly toward the horizon */}
+              <linearGradient id="tracer-sky" x1="0" y1="0" x2="0" y2="1">
+                <stop offset="0" style={{ stopColor: 'var(--bg)' }} />
+                <stop offset="1" style={{ stopColor: 'var(--accent-wash)' }} />
+              </linearGradient>
+              <filter id="tracer-glow" x="-20%" y="-20%" width="140%" height="140%">
+                <feGaussianBlur stdDeviation="3" />
+              </filter>
+            </defs>
+
+            {/* Sky band */}
+            <rect className="ball-tracer__sky" x="0" y="0" width={VIEW_W} height={V_HORIZON} fill="url(#tracer-sky)" />
+            {/* Rough — the ground beyond the fairway. Full width: off-line
+                shots land here, drawn and labeled, never clipped. */}
+            <rect className="ball-tracer__rough" x="0" y={V_HORIZON} width={VIEW_W} height={VIEW_H - V_HORIZON} />
+            <line className="ball-tracer__horizon" x1="0" y1={V_HORIZON} x2={VIEW_W} y2={V_HORIZON} />
+
+            {/* Fairway — 50 yds wide, receding to the horizon */}
+            <polygon className="ball-tracer__fairway" points={groundPoly(FAIRWAY_NEAR_X, RANGE_DEPTH)} />
+            {/* Mow stripes between yardage lines: depth cues, alternating */}
+            {BAND_EDGES.slice(0, -1).map((from, i) =>
+              i % 2 === 1 ? (
+                <polygon key={from} className="ball-tracer__stripe" points={groundPoly(from, BAND_EDGES[i + 1])} />
+              ) : null,
+            )}
+            {/* Fairway edges */}
+            <polyline
+              className="ball-tracer__edge"
+              points={`${project(FAIRWAY_NEAR_X, -HALF_WIDTH, 0).u},${project(FAIRWAY_NEAR_X, -HALF_WIDTH, 0).v} ${project(RANGE_DEPTH, -HALF_WIDTH, 0).u},${project(RANGE_DEPTH, -HALF_WIDTH, 0).v}`}
+            />
+            <polyline
+              className="ball-tracer__edge"
+              points={`${project(FAIRWAY_NEAR_X, HALF_WIDTH, 0).u},${project(FAIRWAY_NEAR_X, HALF_WIDTH, 0).v} ${project(RANGE_DEPTH, HALF_WIDTH, 0).u},${project(RANGE_DEPTH, HALF_WIDTH, 0).v}`}
+            />
+
+            {/* Center aim line */}
+            <line
+              className="ball-tracer__centerline"
+              x1={project(0, 0, 0).u}
+              y1={project(0, 0, 0).v}
+              x2={project(RANGE_DEPTH, 0, 0).u}
+              y2={project(RANGE_DEPTH, 0, 0).v}
+            />
+
+            {/* Width dimension: each half of the fairway is 25 yds from the
+                aim line to the edge, marked on the ground near the tee. */}
+            <text className="ball-tracer__width-label" x={project(6.5, -12.5, 0).u} y={project(6.5, -12.5, 0).v} textAnchor="middle">
+              25 yd
+            </text>
+            <text className="ball-tracer__width-label" x={project(6.5, 12.5, 0).u} y={project(6.5, 12.5, 0).v} textAnchor="middle">
+              25 yd
+            </text>
+
+            {/* Tee mat */}
+            <polygon className="ball-tracer__tee" points={teeMat} />
+
+            {/* Yardage lines: 10, 25, then every 50 to 400 — numbered on
+                BOTH edges the whole way down, sized by depth. */}
+            {DISTANCE_MARKS.map((yds) => {
+              const left = project(yds, -HALF_WIDTH, 0);
+              const right = project(yds, HALF_WIDTH, 0);
+              const labelSize = Math.max(9, Math.min(14, 950 / (yds + 12)));
+              return (
+                <g key={yds}>
+                  <line
+                    className="ball-tracer__distline"
+                    x1={left.u}
+                    y1={left.v}
+                    x2={right.u}
+                    y2={right.v}
+                  />
+                  <text
+                    className="ball-tracer__distlabel"
+                    x={right.u + 6}
+                    y={right.v + labelSize / 3}
+                    fontSize={labelSize}
+                  >
+                    {yds}
+                  </text>
+                  <text
+                    className="ball-tracer__distlabel"
+                    x={left.u - 6}
+                    y={left.v + labelSize / 3}
+                    fontSize={labelSize}
+                    textAnchor="end"
+                  >
+                    {yds}
+                  </text>
+                </g>
+              );
+            })}
+
+            {/* Prior traces, faded */}
+            {priorTraces.map((traj, i) => (
+              <path
+                key={i}
+                className="ball-tracer__trace-prior"
+                d={pathFrom(traj.points)}
+              />
+            ))}
+
+            {/* Latest trace — soft glow under a bright draw-in stroke,
+                keyed to the shot so it replays. The draw is paced to the
+                shot's REAL hang time (flight_time_s from the RK4 sim), and
+                the landing ring fires when the ball would land. */}
+            {latestTraj && (
+              <g
+                key={latestVisible!.timestamp}
+                style={
+                  {
+                    '--trace-duration': `${latestTraj.flight_time_s ?? 0.9}s`,
+                    '--trace-delay': `${(latestTraj.flight_time_s ?? 0.9) * 0.97}s`,
+                    '--trace-apex-delay': `${(latestTraj.flight_time_s ?? 0.9) * 0.45}s`,
+                  } as React.CSSProperties
+                }
+              >
+                <path
+                  className="ball-tracer__trace-glow"
+                  d={pathFrom(latestTraj.points)}
+                  pathLength={1}
+                  filter="url(#tracer-glow)"
+                />
+                <path
+                  className="ball-tracer__trace"
+                  d={pathFrom(latestTraj.points)}
+                  pathLength={1}
+                />
+                {landingPoint && (
+                  <>
+                    <circle
+                      className="ball-tracer__ring"
+                      cx={landingPoint.u}
+                      cy={landingPoint.v}
+                      r={3}
+                    />
+                    <circle
+                      className={`ball-tracer__landing ${landedInRough ? 'ball-tracer__landing--rough' : ''}`}
+                      cx={landingPoint.u}
+                      cy={landingPoint.v}
+                      r={3}
+                    />
+                    <text
+                      className="ball-tracer__marker ball-tracer__marker--carry"
+                      x={landingPoint.u}
+                      y={landingPoint.v - 10}
+                      textAnchor="middle"
+                    >
+                      {Math.round(latestTraj.carry_yards)} yds{landedInRough ? ' · rough' : ''}
+                    </text>
+                  </>
+                )}
+                {apexPoint && (
+                  <text
+                    className="ball-tracer__marker"
+                    x={apexPoint.u}
+                    y={apexPoint.v - 8}
+                    textAnchor="middle"
+                  >
+                    ▴ {formatPeakHeight(latestTraj.apex_yards)} {PEAK_HEIGHT_UNIT}
+                  </text>
+                )}
+              </g>
+            )}
+
+            {/* Honest empty/degraded state */}
+            {!latestTraj && (
+              <text className="ball-tracer__hint" x={16} y={VIEW_H - 14}>
+                {latestVisible ? 'no flight data for last shot' : 'awaiting first shot'}
+              </text>
+            )}
+          </svg>
+        </div>
+      )}
+    </section>
+  );
+}
