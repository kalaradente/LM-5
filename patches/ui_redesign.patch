+++ b/tests/test_ballistics_tour.py
@@ -0,0 +1,74 @@
+"""Golden scorecard: the flight engine vs the TrackMan PGA Tour table.
+
+Conditions: ISA sea level (the module default air density) and RAW carry.
+These rows are transcribed from the tour-averages dataset (ball speed,
+launch, spin → carry, apex, landing angle). If an aero-constant change
+pushes any club outside the tolerances, this fails — retune against the
+whole table rather than nudging constants for one club.
+
+Tolerances are the tuned fit's worst case plus a small margin: per-club
+carry ±8%, apex ±10%; fleet means ≤3% and ≤5%. The PRE-tune constants
+fail this hard (mean apex error was 21.5%), so the test genuinely
+discriminates.
+"""
+
+import pytest
+
+from openflight.ballistics import LaunchConditions, simulate
+
+# club, ball mph, launch deg, spin rpm, carry yds, apex yds
+TOUR_ROWS = [
+    ("driver", 167, 10.9, 2686, 275, 32),
+    ("3-wood", 158, 9.2, 3655, 243, 30),
+    ("5-wood", 152, 9.4, 4350, 230, 31),
+    ("hybrid", 146, 10.2, 4437, 225, 29),
+    ("3-iron", 142, 10.4, 4630, 212, 27),
+    ("4-iron", 137, 11.0, 4836, 203, 28),
+    ("5-iron", 132, 12.1, 5361, 194, 31),
+    ("6-iron", 127, 14.1, 6231, 183, 30),
+    ("7-iron", 120, 16.3, 7097, 172, 32),
+    ("8-iron", 115, 18.1, 7998, 160, 31),
+    ("9-iron", 109, 20.4, 8647, 148, 30),
+    ("pw", 102, 24.2, 9304, 136, 29),
+]
+
+CARRY_TOL = 0.08
+APEX_TOL = 0.10
+MEAN_CARRY_TOL = 0.03
+MEAN_APEX_TOL = 0.05
+
+
+def _fly(ball_mph, launch_deg, spin_rpm):
+    return simulate(LaunchConditions(ball_mph, launch_deg, 0.0, spin_rpm, 0.0, "measured"))
+
+
+@pytest.mark.parametrize("club,ball,launch,spin,carry,apex", TOUR_ROWS)
+def test_tour_row_within_tolerance(club, ball, launch, spin, carry, apex):
+    traj = _fly(ball, launch, spin)
+    carry_err = abs(traj.carry_yards - carry) / carry
+    apex_err = abs(traj.apex_yards - apex) / apex
+    assert carry_err <= CARRY_TOL, (
+        f"{club}: carry {traj.carry_yards:.0f} vs tour {carry} ({carry_err:.1%})"
+    )
+    assert apex_err <= APEX_TOL, (
+        f"{club}: apex {traj.apex_yards:.1f} vs tour {apex} ({apex_err:.1%})"
+    )
+
+
+def test_fleet_means_within_tolerance():
+    carry_errs, apex_errs = [], []
+    for _, ball, launch, spin, carry, apex in TOUR_ROWS:
+        traj = _fly(ball, launch, spin)
+        carry_errs.append(abs(traj.carry_yards - carry) / carry)
+        apex_errs.append(abs(traj.apex_yards - apex) / apex)
+    mean_carry = sum(carry_errs) / len(carry_errs)
+    mean_apex = sum(apex_errs) / len(apex_errs)
+    assert mean_carry <= MEAN_CARRY_TOL, f"mean carry error {mean_carry:.1%}"
+    assert mean_apex <= MEAN_APEX_TOL, f"mean apex error {mean_apex:.1%}"
+
+
+def test_hang_times_are_physical():
+    # Real tour hang times run ~5.5-7 s; a flat-flying model reads short.
+    for club, ball, launch, spin, _, _ in TOUR_ROWS:
+        t = _fly(ball, launch, spin).flight_time_s
+        assert 5.0 <= t <= 8.0, f"{club}: hang time {t:.1f}s outside physical range"
diff --git a/tests/test_server_dirt.py b/tests/test_server_dirt.py
new file mode 100644
index 0000000..9a6284d
--- /dev/null
+++ b/tests/test_server_dirt.py
@@ -0,0 +1,92 @@
+"""Audit U-1 regressions: socket handlers must survive hostile payloads.
+
+The mock server is the surface the whole UI (and any third-party client)
+drives. Before U-1, non-dict payloads to the control handlers threw
+unhandled AttributeErrors that killed the socketio worker thread, and
+unvalidated simulate_custom_shot payloads minted 0/-50/500 mph "shots"
+straight into the session. These tests pin both fixes.
+"""
+
+import math
+
+import pytest
+
+from openflight import server as server_module
+from openflight.server import MockLaunchMonitor
+
+
+@pytest.fixture
+def mock_monitor(monkeypatch):
+    m = MockLaunchMonitor()
+    monkeypatch.setattr(server_module, "monitor", m)
+    monkeypatch.setattr(server_module, "mock_mode", True)
+    return m
+
+
+# --- Non-dict payloads must not raise (they killed the worker thread) ---
+
+@pytest.mark.parametrize("payload", ["speed", 42, None, ["a", "b"]])
+def test_set_session_mode_survives_non_dict(mock_monitor, payload):
+    # Must not raise; unknown/garbage mode reports an error, never crashes.
+    server_module.handle_set_session_mode(payload)
+
+
+@pytest.mark.parametrize("payload", ["driver", 42, None, ["a"]])
+def test_set_club_survives_non_dict(mock_monitor, payload):
+    server_module.handle_set_club(payload)
+
+
+@pytest.mark.parametrize("payload", ["boom", [1, 2, 3], 99, None])
+def test_simulate_custom_shot_survives_non_dict(mock_monitor, payload):
+    server_module.handle_simulate_custom_shot(payload)
+
+
+# --- simulate_custom_shot value hygiene ---
+
+def _last_shot(m):
+    return m.get_shots()[-1]
+
+
+def test_absurd_ball_speed_is_clamped(mock_monitor):
+    server_module.handle_simulate_custom_shot({"ball_speed_mph": 500})
+    assert _last_shot(mock_monitor).ball_speed_mph <= 250.0
+
+
+def test_negative_ball_speed_is_clamped_up(mock_monitor):
+    server_module.handle_simulate_custom_shot({"ball_speed_mph": -50})
+    assert _last_shot(mock_monitor).ball_speed_mph >= 10.0
+
+
+def test_non_finite_and_garbage_fall_back_to_random(mock_monitor):
+    # NaN / string / None must not produce a NaN shot; the mock fills a
+    # plausible random value instead.
+    for bad in (float("nan"), "fast", None, float("inf")):
+        server_module.handle_simulate_custom_shot({"ball_speed_mph": bad})
+        s = _last_shot(mock_monitor)
+        assert math.isfinite(s.ball_speed_mph)
+        assert 10.0 <= s.ball_speed_mph <= 250.0
+
+
+def test_spin_is_clamped_to_physical_range(mock_monitor):
+    server_module.handle_simulate_custom_shot({"ball_speed_mph": 150, "spin_rpm": 100000})
+    assert 0.0 <= _last_shot(mock_monitor).spin_rpm <= 13000.0
+
+
+def test_bad_club_falls_back(mock_monitor):
+    # A non-string / unknown club must not crash; mock keeps its current club.
+    server_module.handle_simulate_custom_shot({"ball_speed_mph": 150, "club": 12345})
+    server_module.handle_simulate_custom_shot({"ball_speed_mph": 150, "club": "banana"})
+    assert _last_shot(mock_monitor).ball_speed_mph >= 10.0
+
+
+def test_downward_launch_produces_no_tracer_trajectory(mock_monitor):
+    # A degenerate flight (clamped launch floor still near-ground) must not
+    # attach a garbage trace; _attach_trajectory bails on sub-yard carries.
+    server_module.handle_simulate_custom_shot(
+        {"ball_speed_mph": 150, "launch_angle_deg": -10}
+    )
+    shot = _last_shot(mock_monitor)
+    # If a trajectory attached at all, it must be a real flight.
+    if shot.trajectory is not None:
+        assert shot.trajectory["carry_yards"] >= 1.0
+        assert shot.trajectory["apex_yards"] >= 0.0
