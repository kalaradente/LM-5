+import { create } from 'zustand';
+
+export type Handedness = 'rh' | 'lh';
+
+const STORAGE_KEY = 'openflight.handedness';
+
+function readStoredHandedness(): Handedness {
+  if (typeof window === 'undefined') {
+    return 'rh';
+  }
+
+  const storedValue = window.localStorage.getItem(STORAGE_KEY);
+  return storedValue === 'lh' ? 'lh' : 'rh';
+}
+
+interface HandednessPreferenceState {
+  handedness: Handedness;
+  setHandedness: (handedness: Handedness) => void;
+}
+
+export const useHandednessPreferenceStore = create<HandednessPreferenceState>((set) => ({
+  handedness: readStoredHandedness(),
+  setHandedness: (handedness) => {
+    if (typeof window !== 'undefined') {
+      window.localStorage.setItem(STORAGE_KEY, handedness);
+    }
+
+    set({ handedness });
+  },
+}));
diff --git a/ui/src/stores/useThemePreferenceStore.ts b/ui/src/stores/useThemePreferenceStore.ts
