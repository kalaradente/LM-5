+++ b/ui/src/data/tourAverages.ts
@@ -0,0 +1,116 @@
+// PGA Tour launch-monitor averages per club, from TrackMan's published
+// tour dataset. Source of truth on this machine:
+//   ~/Desktop/datasheets/pgatourstats/pga_tour_averages_trackman.csv
+// (see DATA_NOTES.md there for provenance). Values below transcribed from
+// that CSV — update here if the CSV is ever refreshed.
+//
+// Every stat the CSV and the pipeline both track gets rated against the
+// tour number for the club the shot was hit with. Bands are PER STAT —
+// blanket percentages make no sense across units (±30% of ball speed
+// would be a ±50 mph window): speeds use absolute mph, carry a
+// percentage, angles absolute degrees, and so on. Outside the band reads
+// LOW or HIGH; inside reads AVG.
+//
+// Clubs without a row in the dataset (2i, 7W, 5H/7H/9H, GW/SW/LW) get no
+// rating rather than an invented reference — honest-instrumentation rule.
+
+export interface TourReference {
+  /** Clubhead speed, mph */
+  club_speed_mph: number;
+  /** Attack angle, degrees (negative = hitting down) */
+  attack_angle_deg: number;
+  /** Ball speed, mph */
+  ball_speed_mph: number;
+  /** Smash factor (ball ÷ club speed) */
+  smash_factor: number;
+  /** Vertical launch angle, degrees */
+  launch_deg: number;
+  /** Total spin, rpm */
+  spin_rpm: number;
+  /** Apex height, yards (displayed in feet everywhere) */
+  max_height_yards: number;
+  /** Carry, yards */
+  carry_yards: number;
+}
+
+export const TOUR_AVERAGES: Record<string, TourReference> = {
+  driver: { club_speed_mph: 113, attack_angle_deg: -1.3, ball_speed_mph: 167, smash_factor: 1.48, launch_deg: 10.9, spin_rpm: 2686, max_height_yards: 32, carry_yards: 275 },
+  '3-wood': { club_speed_mph: 107, attack_angle_deg: -2.9, ball_speed_mph: 158, smash_factor: 1.48, launch_deg: 9.2, spin_rpm: 3655, max_height_yards: 30, carry_yards: 243 },
+  '5-wood': { club_speed_mph: 103, attack_angle_deg: -3.3, ball_speed_mph: 152, smash_factor: 1.47, launch_deg: 9.4, spin_rpm: 4350, max_height_yards: 31, carry_yards: 230 },
+  // TrackMan publishes one hybrid row ("Hybrid 15-18deg"). Loft-wise that's
+  // a 2H; a 3H (~19°) sits within a degree of the range, so both use it.
+  // 4H+ lofts are outside the row — no reference, no rating.
+  '2-hybrid': { club_speed_mph: 100, attack_angle_deg: -3.5, ball_speed_mph: 146, smash_factor: 1.46, launch_deg: 10.2, spin_rpm: 4437, max_height_yards: 29, carry_yards: 225 },
+  '3-hybrid': { club_speed_mph: 100, attack_angle_deg: -3.5, ball_speed_mph: 146, smash_factor: 1.46, launch_deg: 10.2, spin_rpm: 4437, max_height_yards: 29, carry_yards: 225 },
+  '3-iron': { club_speed_mph: 98, attack_angle_deg: -3.1, ball_speed_mph: 142, smash_factor: 1.45, launch_deg: 10.4, spin_rpm: 4630, max_height_yards: 27, carry_yards: 212 },
+  '4-iron': { club_speed_mph: 96, attack_angle_deg: -3.4, ball_speed_mph: 137, smash_factor: 1.43, launch_deg: 11.0, spin_rpm: 4836, max_height_yards: 28, carry_yards: 203 },
+  '5-iron': { club_speed_mph: 94, attack_angle_deg: -3.7, ball_speed_mph: 132, smash_factor: 1.41, launch_deg: 12.1, spin_rpm: 5361, max_height_yards: 31, carry_yards: 194 },
+  '6-iron': { club_speed_mph: 92, attack_angle_deg: -4.1, ball_speed_mph: 127, smash_factor: 1.38, launch_deg: 14.1, spin_rpm: 6231, max_height_yards: 30, carry_yards: 183 },
+  '7-iron': { club_speed_mph: 90, attack_angle_deg: -4.3, ball_speed_mph: 120, smash_factor: 1.33, launch_deg: 16.3, spin_rpm: 7097, max_height_yards: 32, carry_yards: 172 },
+  '8-iron': { club_speed_mph: 87, attack_angle_deg: -4.5, ball_speed_mph: 115, smash_factor: 1.32, launch_deg: 18.1, spin_rpm: 7998, max_height_yards: 31, carry_yards: 160 },
+  '9-iron': { club_speed_mph: 85, attack_angle_deg: -4.7, ball_speed_mph: 109, smash_factor: 1.28, launch_deg: 20.4, spin_rpm: 8647, max_height_yards: 30, carry_yards: 148 },
+  pw: { club_speed_mph: 83, attack_angle_deg: -5.0, ball_speed_mph: 102, smash_factor: 1.23, launch_deg: 24.2, spin_rpm: 9304, max_height_yards: 29, carry_yards: 136 },
+};
+
+export type TourRating = 'low' | 'avg' | 'high';
+
+export type TourStat =
+  | 'ball_speed'
+  | 'club_speed'
+  | 'smash'
+  | 'carry'
+  | 'launch'
+  | 'spin'
+  | 'aoa'
+  | 'peak_ft';
+
+export interface TourComparison {
+  rating: TourRating;
+  /** The tour-average value the shot was compared against, in the stat's
+   * native unit (mph, yds, deg, rpm — peak_ft is FEET). */
+  tourValue: number;
+}
+
+interface StatSpec {
+  /** Pull the reference value (in the stat's native unit) from a row. */
+  ref: (r: TourReference) => number;
+  /** Half-width of the AVG band: absolute in the stat's unit, or a
+   * fraction of the tour value. */
+  band: { abs: number } | { pct: number };
+}
+
+// Per-stat common-sense bands. Example (Johnny's spec): tour ball speed
+// 170 → under 160 reads LOW, over 180 reads HIGH.
+const STAT_SPECS: Record<TourStat, StatSpec> = {
+  ball_speed: { ref: (r) => r.ball_speed_mph, band: { abs: 10 } },
+  club_speed: { ref: (r) => r.club_speed_mph, band: { abs: 6 } },
+  smash: { ref: (r) => r.smash_factor, band: { abs: 0.08 } },
+  carry: { ref: (r) => r.carry_yards, band: { pct: 0.1 } },
+  launch: { ref: (r) => r.launch_deg, band: { abs: 3 } },
+  spin: { ref: (r) => r.spin_rpm, band: { pct: 0.2 } },
+  aoa: { ref: (r) => r.attack_angle_deg, band: { abs: 2 } },
+  peak_ft: { ref: (r) => r.max_height_yards * 3, band: { abs: 15 } },
+};
+
+/**
+ * Rate a measured stat against the tour average for the club, using that
+ * stat's own band. Returns null when the club has no tour reference (or
+ * the value is unusable): the UI shows nothing rather than a made-up
+ * comparison. `value` must be in the stat's native unit (peak_ft: feet).
+ */
+export function rateTourStat(
+  club: string,
+  stat: TourStat,
+  value: number | null,
+): TourComparison | null {
+  if (value === null || !Number.isFinite(value)) return null;
+  const row = TOUR_AVERAGES[club];
+  if (!row) return null;
+
+  const spec = STAT_SPECS[stat];
+  const tourValue = spec.ref(row);
+  const half = 'abs' in spec.band ? spec.band.abs : Math.abs(tourValue) * spec.band.pct;
+  if (value < tourValue - half) return { rating: 'low', tourValue };
