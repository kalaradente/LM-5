+/* Stylized behind-the-golfer projection for the ball tracer.
+   World frame: x downrange, y lateral (+right), z up — all yards.
+
+   Deliberately NOT a pinhole render: true perspective collapses the whole
+   100-400 yd band into ~15 px of horizon (ground positions scale as 1/d),
+   which made every carry look identical and every flight look flat. Like
+   broadcast tracer graphics, depth runs on a square-root curve so far
+   carries stay visibly separated, and height is drawn at a boosted scale
+   tied to the local depth so arcs read as arcs. It's a chart, not a
+   photograph — tuned so bigger carry always lands visibly deeper and
+   higher apex always draws visibly taller. */
+
+export const VIEW_W = 720;
+export const VIEW_H = 460;
+export const RANGE_DEPTH = 420; // yards — beyond any real carry
+export const HALF_WIDTH = 25; // yards — 50 yd wide fairway
+// Fairway's near edge extends toward the viewer so the foreground is
+// ground, not void (maps just past the bottom of the frame).
+export const FAIRWAY_NEAR_X = -3.5;
+
+const V_NEAR = 452; // screen v of the ground at the tee (x = 0)
+export const V_HORIZON = 120; // screen v the fairway converges toward
+const W_NEAR = 330; // half-width in px of the fairway at the tee
+const W_FAR = 26; // half-width in px at RANGE_DEPTH
+// Arc emphasis relative to local lateral scale: high enough that a full
+// flight soars past the horizon line into the sky band.
+const HEIGHT_FACTOR = 0.9;
+
+/** Signed sqrt depth parameter: 0 at the tee, 1 at RANGE_DEPTH. */
+function depthT(x: number): number {
+  const a = Math.abs(x) / RANGE_DEPTH;
+  return Math.sign(x) * Math.sqrt(a);
+}
+
+export function project(x: number, y: number, z: number): { u: number; v: number } {
+  const t = depthT(x);
+  const halfWidthPx = W_NEAR - t * (W_NEAR - W_FAR);
+  const pxPerYd = halfWidthPx / HALF_WIDTH;
+  const groundV = V_NEAR - t * (V_NEAR - V_HORIZON);
+  return {
+    u: VIEW_W / 2 + y * pxPerYd,
+    v: groundV - z * pxPerYd * HEIGHT_FACTOR,
+  };
+}
+
+/** Smooth SVG path through the projected flight samples: CENTRIPETAL
+ * Catmull-Rom converted to cubic Béziers. The sim samples uniformly in
+ * time, so chord lengths are uneven (long off the face, tight at the
+ * apex) — uniform Catmull-Rom wiggles and overshoots at those spacing
+ * transitions; the centripetal parameterization (α = 0.5) doesn't. */
+export function pathFrom(points: [number, number, number][]): string {
+  const pts = points.map(([x, y, z]) => project(x, y, z));
+  if (pts.length === 0) return '';
+  if (pts.length === 1) return `M ${pts[0].u.toFixed(2)} ${pts[0].v.toFixed(2)}`;
+
+  const chord = (a: { u: number; v: number }, b: { u: number; v: number }) =>
+    Math.sqrt(Math.hypot(b.u - a.u, b.v - a.v)); // |Δ|^0.5 — centripetal
+
+  let d = `M ${pts[0].u.toFixed(2)} ${pts[0].v.toFixed(2)}`;
+  for (let i = 0; i < pts.length - 1; i++) {
+    const p0 = pts[Math.max(0, i - 1)];
+    const p1 = pts[i];
+    const p2 = pts[i + 1];
+    const p3 = pts[Math.min(pts.length - 1, i + 2)];
+
+    const d1 = Math.max(chord(p0, p1), 1e-4);
+    const d2 = Math.max(chord(p1, p2), 1e-4);
+    const d3 = Math.max(chord(p2, p3), 1e-4);
+
+    // Standard centripetal CR → Bézier control points
+    const d1sq = d1 * d1;
+    const d2sq = d2 * d2;
+    const d3sq = d3 * d3;
+    const c1u = (d1sq * p2.u - d2sq * p0.u + (2 * d1sq + 3 * d1 * d2 + d2sq) * p1.u) / (3 * d1 * (d1 + d2));
+    const c1v = (d1sq * p2.v - d2sq * p0.v + (2 * d1sq + 3 * d1 * d2 + d2sq) * p1.v) / (3 * d1 * (d1 + d2));
+    const c2u = (d3sq * p1.u - d2sq * p3.u + (2 * d3sq + 3 * d3 * d2 + d2sq) * p2.u) / (3 * d3 * (d3 + d2));
+    const c2v = (d3sq * p1.v - d2sq * p3.v + (2 * d3sq + 3 * d3 * d2 + d2sq) * p2.v) / (3 * d3 * (d3 + d2));
+
+    d += ` C ${c1u.toFixed(2)} ${c1v.toFixed(2)}, ${c2u.toFixed(2)} ${c2v.toFixed(2)}, ${p2.u.toFixed(2)} ${p2.v.toFixed(2)}`;
+  }
+  return d;
+}
