+import { describe, expect, it } from 'vitest';
+import { rateTourStat, TOUR_AVERAGES } from './tourAverages';
+
+describe('rateTourStat — per-stat bands', () => {
+  it('spin uses ±20% of the tour value', () => {
+    // Driver spin tour avg 2686: band is 2148.8 .. 3223.2
+    expect(rateTourStat('driver', 'spin', 2686)?.rating).toBe('avg');
+    expect(rateTourStat('driver', 'spin', 2150)?.rating).toBe('avg');
+    expect(rateTourStat('driver', 'spin', 3220)?.rating).toBe('avg');
+    expect(rateTourStat('driver', 'spin', 2100)?.rating).toBe('low');
+    expect(rateTourStat('driver', 'spin', 3300)?.rating).toBe('high');
+  });
+
+  it('ball speed uses ±10 mph (the "tour 170 → under 160 low, over 180 high" rule)', () => {
+    // Driver ball speed tour avg 167: band is 157 .. 177
+    expect(rateTourStat('driver', 'ball_speed', 156)?.rating).toBe('low');
+    expect(rateTourStat('driver', 'ball_speed', 160)?.rating).toBe('avg');
+    expect(rateTourStat('driver', 'ball_speed', 175)?.rating).toBe('avg');
+    expect(rateTourStat('driver', 'ball_speed', 178)?.rating).toBe('high');
+  });
+
+  it('club speed uses ±6 mph', () => {
+    // Driver club speed tour avg 113: band is 107 .. 119
+    expect(rateTourStat('driver', 'club_speed', 106)?.rating).toBe('low');
+    expect(rateTourStat('driver', 'club_speed', 108)?.rating).toBe('avg');
+    expect(rateTourStat('driver', 'club_speed', 118)?.rating).toBe('avg');
+    expect(rateTourStat('driver', 'club_speed', 120)?.rating).toBe('high');
+  });
+
+  it('smash factor uses ±0.08', () => {
+    // Driver smash tour avg 1.48: band is 1.40 .. 1.56
+    expect(rateTourStat('driver', 'smash', 1.39)?.rating).toBe('low');
+    expect(rateTourStat('driver', 'smash', 1.45)?.rating).toBe('avg');
+    expect(rateTourStat('driver', 'smash', 1.55)?.rating).toBe('avg');
+    expect(rateTourStat('driver', 'smash', 1.57)?.rating).toBe('high');
+  });
+
+  it('carry uses ±10%', () => {
+    // Driver carry tour avg 275: band is 247.5 .. 302.5
+    expect(rateTourStat('driver', 'carry', 240)?.rating).toBe('low');
+    expect(rateTourStat('driver', 'carry', 260)?.rating).toBe('avg');
+    expect(rateTourStat('driver', 'carry', 310)?.rating).toBe('high');
+  });
+
+  it('launch angle uses ±3°', () => {
+    // 7-iron launch tour avg 16.3: band is 13.3 .. 19.3
+    expect(rateTourStat('7-iron', 'launch', 12.9)?.rating).toBe('low');
+    expect(rateTourStat('7-iron', 'launch', 16.0)?.rating).toBe('avg');
+    expect(rateTourStat('7-iron', 'launch', 19.6)?.rating).toBe('high');
+  });
+
+  it('attack angle uses ±2° on the signed value', () => {
+    // Driver AoA tour avg -1.3: band is -3.3 .. 0.7
+    expect(rateTourStat('driver', 'aoa', -4.0)?.rating).toBe('low');
+    expect(rateTourStat('driver', 'aoa', -1.0)?.rating).toBe('avg');
+    expect(rateTourStat('driver', 'aoa', 1.0)?.rating).toBe('high');
+  });
+
+  it('peak height compares in FEET with a ±15 ft band', () => {
+    // Driver apex tour avg 32 yd = 96 ft: band is 81 .. 111
+    expect(rateTourStat('driver', 'peak_ft', 75)?.rating).toBe('low');
+    expect(rateTourStat('driver', 'peak_ft', 90)?.rating).toBe('avg');
+    expect(rateTourStat('driver', 'peak_ft', 115)?.rating).toBe('high');
+    expect(rateTourStat('driver', 'peak_ft', 90)?.tourValue).toBe(96);
+  });
+
+  it('returns the tour reference it compared against', () => {
+    expect(rateTourStat('7-iron', 'spin', 7000)?.tourValue).toBe(7097);
+    expect(rateTourStat('7-iron', 'launch', 16)?.tourValue).toBe(16.3);
+    expect(rateTourStat('7-iron', 'ball_speed', 118)?.tourValue).toBe(120);
+    expect(rateTourStat('7-iron', 'carry', 170)?.tourValue).toBe(172);
+  });
+
+  it('returns null for clubs without a tour reference', () => {
+    expect(rateTourStat('sw', 'spin', 10000)).toBeNull();
+    expect(rateTourStat('2-iron', 'launch', 12)).toBeNull();
+    expect(rateTourStat('mini-driver', 'ball_speed', 160)).toBeNull();
+    expect(rateTourStat('not-a-club', 'carry', 250)).toBeNull();
+  });
+
+  it('returns null for missing values', () => {
+    expect(rateTourStat('driver', 'spin', null)).toBeNull();
+    expect(rateTourStat('driver', 'ball_speed', NaN)).toBeNull();
+  });
+
+  it('rates the exact tour value as avg for every stat and club', () => {
+    for (const [club, ref] of Object.entries(TOUR_AVERAGES)) {
+      expect(rateTourStat(club, 'launch', ref.launch_deg)?.rating).toBe('avg');
+      expect(rateTourStat(club, 'spin', ref.spin_rpm)?.rating).toBe('avg');
+      expect(rateTourStat(club, 'ball_speed', ref.ball_speed_mph)?.rating).toBe('avg');
+      expect(rateTourStat(club, 'club_speed', ref.club_speed_mph)?.rating).toBe('avg');
+      expect(rateTourStat(club, 'smash', ref.smash_factor)?.rating).toBe('avg');
+      expect(rateTourStat(club, 'carry', ref.carry_yards)?.rating).toBe('avg');
+      expect(rateTourStat(club, 'aoa', ref.attack_angle_deg)?.rating).toBe('avg');
+      expect(rateTourStat(club, 'peak_ft', ref.max_height_yards * 3)?.rating).toBe('avg');
+    }
+  });
