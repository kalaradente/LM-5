+@socketio.on("simulate_custom_shot")
+def handle_simulate_custom_shot(data):
+    """Simulate a shot from explicit launch conditions (only works in mock mode).
+
+    Payload: {"ball_speed_mph": float, "spin_rpm": float,
+              "launch_angle_deg": float, "side_angle_deg": float,
+              "spin_axis_deg": float, "club": str}
+    Any field can be omitted; omitted fields fall back to the same
+    TrackMan-based random generation as simulate_shot(). Used by the
+    plaintext shot simulator (see shot_simulator.py) to inject typed-in
+    launch conditions and have them rendered by the real UI + physics engine.
+    spin_axis_deg drives the fade/draw curve; side_angle_deg is just the
+    initial aim/push-pull direction, independent of the curve.
+    """
+    if monitor and isinstance(monitor, MockLaunchMonitor):
+        monitor.simulate_shot(
+            ball_speed=data.get("ball_speed_mph"),
+            spin_rpm=data.get("spin_rpm"),
+            launch_v=data.get("launch_angle_deg"),
+            launch_h=data.get("side_angle_deg"),
+            spin_axis=data.get("spin_axis_deg"),
+            club=data.get("club"),
+        )
+
