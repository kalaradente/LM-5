@@ -0,0 +1,42 @@
+import { useSystemStore } from '../stores/useSystemStore';
+import { socketService } from '../services/socketService';
+import './SessionModePicker.css';
+
+/**
+ * Three-way acquisition mode selector: Indoor / Outdoor / Speed.
+ *
+ * Renders only when the connected monitor reports a session mode (i.e. it
+ * supports live switching — the IWR6843 hardware monitor). Selecting a mode
+ * emits set_session_mode; the active button follows the server's
+ * session_mode broadcast rather than local state, so every connected
+ * client's picker stays in sync and a rejected switch never lies.
+ */
+const MODES: { id: string; label: string }[] = [
+  { id: 'indoor', label: 'Indoor' },
+  { id: 'outdoor', label: 'Outdoor' },
+  { id: 'speed', label: 'Speed' },
+];
+
+export function SessionModePicker() {
+  const sessionMode = useSystemStore((state) => state.sessionMode);
+
+  if (!sessionMode) return null;
+
+  return (
+    <div className="session-mode-picker" role="group" aria-label="Session mode">
+      {MODES.map((mode) => (
+        <button
+          key={mode.id}
+          type="button"
+          className={`session-mode-picker__button ${
+            sessionMode === mode.id ? 'session-mode-picker__button--active' : ''
+          }`}
+          onClick={() => socketService.setSessionMode(mode.id)}
+          aria-pressed={sessionMode === mode.id}
+        >
+          {mode.label}
+        </button>
+      ))}
+    </div>
+  );
+}
