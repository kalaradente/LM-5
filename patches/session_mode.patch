diff --git a/ui/src/components/SwingDisplay.tsx b/ui/src/components/SwingDisplay.tsx
new file mode 100644
index 0000000..65d83c8
--- /dev/null
+++ b/ui/src/components/SwingDisplay.tsx
@@ -0,0 +1,101 @@
+import type { Shot } from '../types/shot';
+import { useUnitPreference } from '../state/useUnitPreference';
+import { formatSpeed, getSpeedUnit } from '../utils/units';
+import { MetricCard } from './ShotDisplay';
+import { ReorderableGrid, type GridItem } from './ReorderableGrid';
+import './ShotDisplay.css';
+
+interface SwingDisplayProps {
+  shots: Shot[];
+  latestShot: Shot | null;
+  animate?: boolean;
+}
+
+/**
+ * Live view for speed-training mode: club-head speed is the only metric.
+ *
+ * Swings arrive on the same "shot" stream, tagged mode === "speed-training"
+ * with ball_speed_mph structurally 0 — this view reads ONLY the club speed
+ * and the session aggregates overspeed protocols train against (session
+ * max, average, rep count). Same uniform, reorderable card grid the shot
+ * view uses; club speed is a box exactly like the rest.
+ */
+export function SwingDisplay({ shots, latestShot, animate = false }: SwingDisplayProps) {
+  const { unitSystem } = useUnitPreference();
+
+  const swings = shots.filter(
+    (s) => s.mode === 'speed-training' && s.club_speed_mph !== null
+  );
+  const latest =
+    latestShot?.mode === 'speed-training' && latestShot.club_speed_mph !== null
+      ? latestShot
+      : swings.length > 0
+        ? swings[swings.length - 1]
+        : null;
+
+  if (!latest) {
+    return (
+      <div className="shot-display shot-display--empty">
+        <div className="shot-display__waiting">
+          <p className="shot-display__waiting-text">Speed training</p>
+          <p className="shot-display__waiting-hint">
+            Swing away — no ball needed. Club-head speed only.
+          </p>
+        </div>
+      </div>
+    );
+  }
+
+  const speeds = swings.map((s) => s.club_speed_mph!);
+  const maxSpeed = Math.max(...speeds);
+  const avgSpeed = speeds.reduce((a, b) => a + b, 0) / speeds.length;
+  const isSessionBest = latest.club_speed_mph! >= maxSpeed && swings.length > 1;
+  const speedUnit = getSpeedUnit(unitSystem);
+
+  const items: GridItem[] = [
+    {
+      id: 'club_speed',
+      content: (
+        <MetricCard
+          value={formatSpeed(latest.club_speed_mph!, unitSystem, 1)}
+          unit={speedUnit}
+          label="Club Speed"
+          subtext={isSessionBest ? 'session best!' : undefined}
+          variant="primary"
+        />
+      ),
+    },
+    {
+      id: 'session_max',
+      content: (
+        <MetricCard
+          value={formatSpeed(maxSpeed, unitSystem, 1)}
+          unit={speedUnit}
+          label="Session Max"
+          variant="primary"
+        />
+      ),
+    },
+    {
+      id: 'session_avg',
+      content: (
+        <MetricCard
+          value={formatSpeed(avgSpeed, unitSystem, 1)}
+          unit={speedUnit}
+          label="Session Avg"
+          variant="secondary"
+        />
+      ),
+    },
+    {
+      id: 'swing_count',
+      content: <MetricCard value={swings.length} label="Swings" variant="secondary" />,
+    },
+  ];
+
+  return (
+    <div className={`shot-display ${animate ? 'shot-display--animate' : ''}`}>
+      <ReorderableGrid items={items} storageKey="openflight.metricOrder.swing" />
+    </div>
+  );
+}
