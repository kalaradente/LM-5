+@socketio.on("set_session_mode")
+def handle_set_session_mode(data=None):
+    """Switch the acquisition session mode (indoor / outdoor / speed) live.
+
+    Control-plane only: the payload is a single whitelisted-by-the-monitor
+    mode string, validated and applied by the monitor's own
+    set_session_mode() -- no shot data can be injected through this event
+    (the mock-only simulate_custom_shot posture is unaffected). Monitors
+    that don't support live mode switching (mock, rolling-buffer) simply
+    don't expose the method and the event reports unsupported.
+    """
+    mode = (data or {}).get("mode")
+    if not monitor or not hasattr(monitor, "set_session_mode"):
+        socketio.emit(
+            "session_mode_error",
+            {"error": "This launch monitor does not support mode switching"},
+        )
+        return
+    try:
+        result = monitor.set_session_mode(mode)
+        # Broadcast so every connected client's picker moves together.
+        socketio.emit("session_mode", result)
+        logger.info("[SERVER] Session mode -> %s", mode)
+        session_logger = get_session_logger()
+        if session_logger:
+            session_logger.log_config_change(
+                {"session_mode": mode}, source="user"
+            )
+    except ValueError as e:
+        socketio.emit("session_mode_error", {"error": str(e)})
+    except Exception as e:
+        logger.warning("[SERVER] Error setting session mode: %s", e, exc_info=True)
+        socketio.emit("session_mode_error", {"error": str(e)})
+
+
+@socketio.on("get_session_mode")
+def handle_get_session_mode():
+    """Report the current session mode (absent on monitors without one)."""
+    if monitor and hasattr(monitor, "get_session_mode"):
+        socketio.emit("session_mode", monitor.get_session_mode())
+
+
 @socketio.on("shutdown")
 def handle_shutdown():
     """Cleanly shut down the server and all hardware."""
