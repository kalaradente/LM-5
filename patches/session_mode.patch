diff --git a/ui/src/components/ReorderableGrid.css b/ui/src/components/ReorderableGrid.css
new file mode 100644
index 0000000..642da27
--- /dev/null
+++ b/ui/src/components/ReorderableGrid.css
@@ -0,0 +1,42 @@
+/* Responsive, drag-reorderable metric grid (session_mode patch). */
+.reorder-grid {
+  display: grid;
+  /* Reflow: as many ~150px columns as fit, each stretching to share the
+     width. Wide window = more columns; narrow window = fewer, down to one
+     on a phone — no per-breakpoint rules needed. */
+  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
+  gap: var(--space-sm);
+  align-content: start;
+  width: 100%;
+}
+
+.reorder-grid__cell {
+  display: flex;
+  /* Normal touch behavior (scroll/zoom) until a drag actually starts; the
+     hold timer only fires when the finger is stationary, so the page still
+     scrolls under a swipe. */
+  touch-action: manipulation;
+  cursor: grab;
+  transition: transform 0.15s ease, opacity 0.15s ease;
+}
+
+.reorder-grid__cell > * {
+  width: 100%;
+}
+
+/* While a drag is active, suppress scroll and text selection so the lift
+   gesture is clean. */
+.reorder-grid--dragging {
+  touch-action: none;
+  user-select: none;
+}
+
+.reorder-grid__cell--dragging {
+  opacity: 0.65;
+  transform: scale(1.04);
+  cursor: grabbing;
+  /* Let elementFromPoint see the card UNDER the pointer, not the lifted
+     one, so we can compute the drop target. */
+  pointer-events: none;
+  z-index: 2;
+}
diff --git a/ui/src/components/ReorderableGrid.tsx b/ui/src/components/ReorderableGrid.tsx
new file mode 100644
index 0000000..be9bcac
--- /dev/null
+++ b/ui/src/components/ReorderableGrid.tsx
@@ -0,0 +1,184 @@
+import { useEffect, useRef, useState } from 'react';
+import './ReorderableGrid.css';
+
+function loadOrder(storageKey: string): string[] {
+  try {
+    const raw = localStorage.getItem(storageKey);
+    return raw ? JSON.parse(raw) : [];
+  } catch {
+    return [];
+  }
+}
+
+export interface GridItem {
+  id: string;
+  content: React.ReactNode;
+}
+
+interface ReorderableGridProps {
+  items: GridItem[];
+  /** localStorage key under which the user's chosen order is persisted. */
+  storageKey: string;
+}
+
+// Hold this long (stationary) before a card lifts into drag mode. Long
+// enough that a scroll swipe doesn't accidentally start a drag; short
+// enough to feel responsive on a press-and-hold.
+const HOLD_MS = 280;
+// If the pointer travels this far before the hold fires, treat it as a
+// scroll/swipe and abandon the drag attempt.
+const MOVE_CANCEL_PX = 8;
+
+/**
+ * A responsive grid of cards that (a) reflows to fit its width — more
+ * columns when wide, fewer when narrow — and (b) lets the user press-and-
+ * hold a card to drag it to a new position. The chosen order is remembered
+ * per `storageKey` in localStorage.
+ *
+ * Pointer-events based so it works identically with mouse and touch. No
+ * drag library dependency (keeps the upstream patch self-contained).
+ */
+export function ReorderableGrid({ items, storageKey }: ReorderableGridProps) {
+  const [order, setOrder] = useState<string[]>(() => loadOrder(storageKey));
+  const [draggingId, setDraggingId] = useState<string | null>(null);
+  const holdTimer = useRef<number | null>(null);
+  const startPt = useRef<{ x: number; y: number } | null>(null);
+  const gridRef = useRef<HTMLDivElement | null>(null);
+  // Mirror of draggingId for the native listener below; kept in sync at
+  // the exact points draggingId changes (hold-fire and drag-end), because
+  // the listener is bound once and must not read stale state.
+  const draggingRef = useRef<string | null>(null);
+
+  // Native non-passive touchmove guard (audit M-2): browsers latch
+  // touch-action at GESTURE START, so flipping the CSS class after the
+  // hold fires cannot stop the pan — the first finger movement would
+  // hijack the drag into a page scroll and fire pointercancel. Since no
+  // scroll has begun while the finger held still, preventDefault on the
+  // first post-hold touchmove reliably keeps the gesture ours. React
+  // attaches touch listeners passively, hence the manual addEventListener.
+  useEffect(() => {
+    const el = gridRef.current;
+    if (!el) return;
+    const onTouchMove = (ev: TouchEvent) => {
+      if (draggingRef.current) ev.preventDefault();
+    };
+    el.addEventListener('touchmove', onTouchMove, { passive: false });
+    return () => el.removeEventListener('touchmove', onTouchMove);
+  }, []);
+
+  // Reconcile persisted order with the items actually present this render:
+  // saved order first (dropping any that disappeared), then any new ids in
+  // their natural order. A metric that appears later (e.g. spin once
+  // decoded) lands at the end rather than jumping the user's arrangement.
+  const byId = new Map(items.map((i) => [i.id, i]));
+  const ordered: GridItem[] = [];
+  const seen = new Set<string>();
+  for (const id of order) {
+    const it = byId.get(id);
+    if (it) {
+      ordered.push(it);
+      seen.add(id);
+    }
+  }
+  for (const it of items) {
+    if (!seen.has(it.id)) ordered.push(it);
+  }
+
+  const currentIds = () => ordered.map((i) => i.id);
+
+  const clearHold = () => {
+    if (holdTimer.current !== null) {
+      clearTimeout(holdTimer.current);
+      holdTimer.current = null;
+    }
+  };
+
+  const persist = (ids: string[]) => {
+    try {
+      localStorage.setItem(storageKey, JSON.stringify(ids));
+    } catch {
+      /* ignore */
+    }
+  };
+
+  const onPointerDown = (e: React.PointerEvent, id: string) => {
+    // Touch or left mouse button only.
+    if (e.pointerType === 'mouse' && e.button !== 0) return;
+    const cell = e.currentTarget as HTMLElement;
+    const pid = e.pointerId;
+    startPt.current = { x: e.clientX, y: e.clientY };
+    clearHold();
+    holdTimer.current = window.setTimeout(() => {
+      // Freeze the current visible order into state so live reordering has
+      // a stable base, then lift this card.
+      setOrder(currentIds());
+      draggingRef.current = id;
+      setDraggingId(id);
+      try {
+        cell.setPointerCapture(pid);
+      } catch {
+        /* capture unsupported */
+      }
+    }, HOLD_MS);
+  };
+
+  const onPointerMove = (e: React.PointerEvent) => {
+    if (!draggingId) {
+      // Still in the hold window — bail out of the drag if the user is
+      // clearly scrolling.
+      if (startPt.current) {
+        const dx = Math.abs(e.clientX - startPt.current.x);
+        const dy = Math.abs(e.clientY - startPt.current.y);
+        if (dx > MOVE_CANCEL_PX || dy > MOVE_CANCEL_PX) clearHold();
+      }
+      return;
+    }
+    e.preventDefault();
+    const el = document.elementFromPoint(e.clientX, e.clientY);
+    const target = el?.closest('[data-rg-id]') as HTMLElement | null;
+    const targetId = target?.dataset.rgId;
+    if (!targetId || targetId === draggingId) return;
+    setOrder((prev) => {
+      const ids = prev.length ? [...prev] : currentIds();
+      const from = ids.indexOf(draggingId);
+      const to = ids.indexOf(targetId);
+      if (from === -1 || to === -1) return prev;
+      ids.splice(from, 1);
+      ids.splice(to, 0, draggingId);
+      return ids;
+    });
+  };
+
+  const endDrag = () => {
+    clearHold();
+    if (draggingId) {
+      persist(currentIds());
+      draggingRef.current = null;
+      setDraggingId(null);
+    }
+    startPt.current = null;
+  };
+
+  return (
+    <div
+      ref={gridRef}
+      className={`reorder-grid ${draggingId ? 'reorder-grid--dragging' : ''}`}
+      onPointerMove={onPointerMove}
+      onPointerUp={endDrag}
+      onPointerCancel={endDrag}
+    >
+      {ordered.map((item) => (
+        <div
+          key={item.id}
+          data-rg-id={item.id}
+          className={`reorder-grid__cell ${
+            draggingId === item.id ? 'reorder-grid__cell--dragging' : ''
+          }`}
+          onPointerDown={(e) => onPointerDown(e, item.id)}
+        >
+          {item.content}
+        </div>
+      ))}
+    </div>
+  );
+}
